# ═══════════════════════════════════════════════════════════════
# KAD 1.0 — Environment Configuration
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ═══ MQTT Broker (Mosquitto on AMDY) ═══
MQTT_BROKER=192.168.0.1
MQTT_PORT=1883
MQTT_CLIENT_ID_AMDY=amdy-kad-bridge
MQTT_CLIENT_ID_TELL=tell-kad-node
# MQTT_USERNAME=kad
# MQTT_PASSWORD=

# ═══ Odysseus AI (on AMDY) ═══
ODYSSEUS_URL=http://localhost:7000
ODYSSEUS_API_TOKEN=
# Token is created via: POST /api/auth/api-tokens
# See: amdy/scripts/install.sh for automated setup

# ═══ Network Topology ═══
AMDY_HOST=192.168.0.1
TELL_HOST=192.168.0.2
TELL_SSH_USER=tell

# ═══ TELL Node Paths ═══
TELL_INBOX_PATH=/srv/kad/inbox
TELL_PROCESSED_PATH=/srv/kad/processed
# Subdirectories created automatically:
# inbox/images/, inbox/audio/, inbox/text/, inbox/documents/, inbox/misc/

# ═══ Embedding Configuration ═══
# Phase 1: Remote API
# EMBEDDING_URL=https://api.openai.com/v1/embeddings
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=sk-...

# Phase 2: Local (Ollama on AMDY)
# EMBEDDING_URL=http://localhost:11434/v1/embeddings
# EMBEDDING_MODEL=all-minilm:l6-v2

# ═══ ChromaDB (on AMDY) ═══
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
KAD_COLLECTION=kad_knowledge

# ═══ Logging ═══
LOG_LEVEL=INFO
LOG_FILE=/var/log/kad/kad-bridge.log
